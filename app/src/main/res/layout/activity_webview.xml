<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Khoảng trên cùng hiển thị ảnh biển số đã cắt ra để OCR, giúp đối chiếu khi thao tác trên web -->
    <ImageView
        android:id="@+id/imgPlate"
        android:layout_width="0dp"
        android:layout_height="110dp"
        android:scaleType="fitCenter"
        android:background="#111111"
        android:contentDescription="Ảnh biển số"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <WebView
        android:id="@+id/webView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/imgPlate"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnManageCredentials"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="10dp"
        android:text="🔑"
        android:textSize="16sp"
        android:background="#88000000"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/imgPlate"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnPriceList"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="10dp"
        android:text="💲 Giá"
        android:textSize="16sp"
        android:background="#88000000"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/imgPlate"
        app:layout_constraintEnd_toStartOf="@id/btnManageCredentials" />

    <!-- Lớp phủ bảng giá, độ mờ giống các nút nổi, che toàn màn hình, ẩn theo mặc định -->
    <FrameLayout
        android:id="@+id/priceOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#CC000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bảng giá theo loại xe"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnClosePriceList"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="10dp"
                    android:text="✕"
                    android:textSize="16sp"
                    android:background="#88000000"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/priceTableContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </ScrollView>

        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
